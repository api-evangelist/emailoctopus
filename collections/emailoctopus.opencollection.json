          },
          "docs": "Create field"
        },
        {
          "info": {
            "name": "Update field",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.emailoctopus.com/lists/{list_id}/fields/{tag}",
            "body": {
              "type": "json",
              "data": "{\"label\": \"<string>\"}"
            }
          },
          "docs": "Update field"
        },
        {
          "info": {
            "name": "Delete field",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.emailoctopus.com/lists/{list_id}/fields/{tag}"
          },
          "docs": "Delete field"
        }

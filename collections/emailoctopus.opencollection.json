    },
    {
      "info": {
        "name": "Automation",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Start an automation for a contact",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.emailoctopus.com/automations/{automation_id}/queue",
            "body": {
              "type": "json",
              "data": "{\"list_id\": \"<string>\", \"contact_id\": \"<string>\"}"
            }
          },
          "docs": "Start an automation for a contact"
        }
      ]
    }
  ]
}
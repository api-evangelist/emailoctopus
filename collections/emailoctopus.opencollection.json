        {
          "info": {
            "name": "Campaign summary report",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.emailoctopus.com/campaigns/{campaign_id}/reports/summary"
          },
          "docs": "Campaign summary report"
        },
        {
          "info": {
            "name": "Campaign links report",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.emailoctopus.com/campaigns/{campaign_id}/reports/links"
          },
          "docs": "Campaign links report"
        }
